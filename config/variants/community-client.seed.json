{
  "variant": "community",
  "display_name": "Open Client",
  "brand_policy": {
    "uses_pokrov_logo": false,
    "default_brand_asset": "",
    "forks_should_replace_brand": true
  },
  "service_model": {
    "uses_managed_service_api": false,
    "default_profile_source": "local_key_or_subscription",
    "support_api": "disabled_by_default",
    "billing": "none"
  },
  "user_features": {
    "paste_key": true,
    "local_profiles": {
      "multi_profile_list": true,
      "select_active": true,
      "replace": true,
      "remove": true
    },
    "supported_single_key_schemes": [
      "vless",
      "trojan",
      "ss",
      "vmess"
    ],
    "subscription_url": "manual_foreground_and_in_app_scheduler",
    "subscription_refresh_policy": {
      "manual_refresh": true,
      "refresh_on_resume_when_stale": true,
      "foreground_scheduler": true,
      "os_background_scheduler": false,
      "default_interval_minutes": 30,
      "default_stale_after_minutes": 30,
      "failed_refresh_preserves_profiles": true
    },
    "qr_import": "android_windows_camera_mvp",
    "warp_policy": "local_user_controlled",
    "routing_modes": [
      "full_tunnel",
      "selected_apps",
      "all_except_region"
    ],
    "free_vpn_catalog": {
      "enabled_by_default": false,
      "first_candidate": "AvenCores/goida-vpn-configs",
      "requires_license_and_parser_review": true,
      "ui_surface": "gated_opt_in",
      "catalog_file": "../free-vpn-catalog.seed.json"
    }
  },
  "build_defines": {
    "OPEN_CLIENT_VARIANT": "community",
    "OPEN_CLIENT_BRAND_NAME": "Open Client",
    "OPEN_CLIENT_ANDROID_PACKAGE_NAME": "org.pokrovclient.community",
    "OPEN_CLIENT_BRAND_ASSET": ""
  }
}
