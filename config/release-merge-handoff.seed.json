{
  "schema_version": 1,
  "script": "scripts/prepare-release-merge-handoff.ps1",
  "default_output_dir": "build/release-merge-handoff",
  "policy": {
    "read_only": true,
    "no_merge": true,
    "no_git_push": true,
    "no_tag_creation": true,
    "no_github_release_publish": true,
    "writes_only_ignored_build_output": true,
    "requires_merge_order_summary": true,
    "requires_github_status_summary": true,
    "requires_tag_readiness_summary": true,
    "requires_publication_dry_run_summary": true,
    "requires_input_fingerprints": true,
    "requires_tag_readiness_input_fingerprints": true,
    "requires_publication_dry_run_input_fingerprints": true,
    "requires_publication_dry_run_evidence_bundle_input_fingerprints": true,
    "requires_publication_dry_run_evidence_bundle_preflight_artifact_fingerprints": true,
    "requires_source_only_summary_flags": true,
    "requires_canonical_build_input_roots": true,
    "requires_input_generated_at": true,
    "requires_input_schema_versions": true,
    "requires_read_only_input_summaries": true,
    "requires_input_stack_count_consistency": true,
    "requires_error_free_input_summaries": true,
    "requires_tag_readiness_blocker_count_consistency": true,
    "requires_tag_readiness_blocker_entry_shape": true,
    "requires_tag_readiness_ready_flags_consistency": true,
    "requires_tag_readiness_blocker_absence_consistency": true,
    "requires_tag_readiness_blocker_evidence_fields": true,
    "requires_tag_readiness_latest_pr_consistency": true,
    "requires_blocker_inventory_latest_candidate_consistency": true,
    "requires_blocker_inventory_latest_pr_consistency": true,
    "requires_publication_dry_run_artifact_fingerprint_integrity": true,
    "requires_publication_dry_run_commit_sha_consistency": true,
    "requires_publication_dry_run_ref_commit_sha_consistency": true,
    "requires_latest_pr_url_consistency": true,
    "requires_expected_repository_pr_url_consistency": true,
    "requires_github_status_expected_pr_url_prefix_consistency": true,
    "requires_github_status_count_consistency": true,
    "requires_github_status_pull_request_entries": true,
    "requires_github_status_pr_sequence": true,
    "requires_github_status_pr_refs": true
  },
  "inputs": {
    "merge_order": "build/release-merge-order/release-merge-order.json",
    "github_status": "build/release-stack-github-status/release-stack-github-status.json",
    "tag_readiness": "build/source-tag-readiness/v0.99.0-source/v0.99.0-source-tag-readiness.json",
    "publication_dry_run": "build/source-release-publication/v0.99.0-source/v0.99.0-source-publication-dry-run.json"
  },
  "input_roots": {
    "merge_order": "build/release-merge-order",
    "github_status": "build/release-stack-github-status",
    "tag_readiness": "build/source-tag-readiness",
    "publication_dry_run": "build/source-release-publication"
  }
}
