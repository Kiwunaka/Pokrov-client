{
  "schema_version": 1,
  "script": "scripts/prepare-release-merge-handoff.ps1",
  "default_output_dir": "build/release-merge-handoff",
  "policy": {
    "read_only": true,
    "no_merge": true,
    "no_git_push": true,
    "no_tag_creation": true,
    "no_github_release_publish": true,
    "writes_only_ignored_build_output": true,
    "requires_merge_order_summary": true,
    "requires_github_status_summary": true,
    "requires_tag_readiness_summary": true,
    "requires_publication_dry_run_summary": true,
    "requires_input_fingerprints": true,
    "requires_source_only_summary_flags": true,
    "requires_canonical_build_input_roots": true,
    "requires_input_generated_at": true
  },
  "inputs": {
    "merge_order": "build/release-merge-order/release-merge-order.json",
    "github_status": "build/release-stack-github-status/release-stack-github-status.json",
    "tag_readiness": "build/source-tag-readiness/v0.60.0-source-tag-readiness.json",
    "publication_dry_run": "build/source-release-publication/v0.60.0-source/v0.60.0-source-publication-dry-run.json"
  },
  "input_roots": {
    "merge_order": "build/release-merge-order",
    "github_status": "build/release-stack-github-status",
    "tag_readiness": "build/source-tag-readiness",
    "publication_dry_run": "build/source-release-publication"
  }
}
