# Local-only seed config for the next-client scaffold.
# Copy with scripts/bootstrap-local.ps1 when you want a disposable workstation seed.

POKROV_ENV=local
POKROV_PLATFORM=android
POKROV_API_BASE_URL=https://api.pokrov.space/
POKROV_APP_BASE_URL=https://app.pokrov.space/
POKROV_CONNECT_URL=https://connect.pokrov.space/
POKROV_DEFAULT_RUNTIME_CORE=sing-box
POKROV_ADVANCED_FALLBACK_CORE=xray
POKROV_DEFAULT_ROUTE_MODE=full_tunnel
POKROV_ENABLE_ENGINE_LOGS=false
