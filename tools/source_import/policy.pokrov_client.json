{
  "allow": [
    "README.md",
    "DESIGN.md",
    "melos.yaml",
    "program.seed.yaml",
    "apps/README.md",
    "apps/android_shell/README.md",
    "apps/android_shell/analysis_options.yaml",
    "apps/android_shell/lib/**/*.dart",
    "apps/android_shell/test/**/*.dart",
    "apps/android_shell/android/**/*.gradle",
    "apps/android_shell/android/**/*.properties",
    "apps/android_shell/android/settings.gradle",
    "apps/windows_shell/README.md",
    "apps/windows_shell/analysis_options.yaml",
    "apps/windows_shell/lib/**/*.dart",
    "apps/windows_shell/test/**/*.dart",
    "apps/windows_shell/windows/**/*.cpp",
    "apps/windows_shell/windows/**/*.h",
    "apps/windows_shell/windows/**/*.cmake",
    "apps/windows_shell/windows/**/CMakeLists.txt",
    "packages/**/README.md",
    "packages/**/pubspec.yaml",
    "packages/**/lib/**/*.dart",
    "packages/**/test/**/*.dart",
    "config/*.seed.json",
    "config/templates/*.example",
    "assets/branding/README.md",
    "assets/branding/*.png"
  ],
  "deny": [
    "**/.git/**",
    "**/.dart_tool/**",
    "**/build/**",
    "**/artifacts/**",
    "**/releases/**",
    "**/config/local/**",
    "**/resources/runtime/**",
    "**/*.env",
    "**/.env",
    "**/.env.*",
    "**/*.key",
    "**/*.pem",
    "**/*.p12",
    "**/*.pfx",
    "**/*.jks",
    "**/*.keystore",
    "**/*.dll",
    "**/*.exe",
    "**/*.aar",
    "**/*.jar",
    "**/*.dylib",
    "**/*.so",
    "**/firebase_options.dart",
    "**/google-services.json",
    "**/GoogleService-Info.plist",
    "**/local.properties",
    "**/release-handoff*.json"
  ]
}
